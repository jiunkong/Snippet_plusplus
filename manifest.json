{
  "manifest_version": 3,
  "name": "__MSG_app_name__",
  "version": "1.0",
  "description": "__MSG_app_description__",
  "default_locale": "ko",
  "permissions": [
    "storage",
    "clipboardRead",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content.css",
        "styles/prompt.css"
      ],
      "js": [
        "utils/constants.js",
        "utils/triggers.js",
        "content/evaluator.js",
        "content/state.js",
        "content/settings.js",
        "content/template.js",
        "content/dom.js",
        "content/effects.js",
        "content/handlers.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "Snippet++ Options",
    "default_icon": {
      "32": "icons/icon32.png",
      "64": "icons/icon64.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}